package newdemo;

public class duplicateelementarray {

	public static void main(String[] args) {
		
		//original array with duplicate values
		int arr[] = {1, 2, 3, 2, 4, 5, 1};
		
		
		//loop through each element of the array
		for(int i=0; i<arr.length; i++)
		{
			//variable to count duplicate occurrences
			int count=0;
			
			//compares the current element with previous elements
			for(int j=0;j<i;j++)
			{
				//check if current element is already present 
				if(arr[i]==arr[j])
				{
					//increases count if duplicate is found 
					count++;
				}
			}
			
			//prints the element only if it is not a duplicate
			if(count>0)
			{
				System.out.print(arr[i] + " ");
			}
		}
	}
	}

