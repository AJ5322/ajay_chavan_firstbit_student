package newdemo;

public class Second_smallest_number_array {

	public static void main(String[] args) {
		
		int arr[] = {12,5,8,3,9};
		
		int smallest = Integer.MAX_VALUE;
		int secondsmallest = Integer.MAX_VALUE;
		
		for(int i=0;i<arr.length;i++)
		{
			if(arr[i] < smallest)
			{
				//when a new smallest element is found 
				//move the old smallest element to secondsmallest
				secondsmallest = smallest;	
				
				//store the new smallest element
				smallest = arr[i];
			}
			
					//If current element is smaller than secondsmallest
					//and it is not equal to the smallest element
					//thenn update secondsmallest
			else if(arr[i] < secondsmallest && arr[i] != smallest)
			{
				secondsmallest = arr[i];
			}
		}
		
		System.out.println("Second smallest element :"+secondsmallest);
	}
}





