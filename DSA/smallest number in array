package newdemo;

public class smallest_number_array {

	public static void main(String[] args) {
		
		int arr[] = {12,5,8,3,9};
		
		int min = arr[0];
		
		for(int i=1;i<arr.length;i++)
		{
			if(arr[i]<min)
			{
				min = arr[i];
			}
		}
		System.out.println("Smallest no in array:"+min);
		
	}
}
